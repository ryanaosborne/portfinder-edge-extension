{
  "manifest_version": 3,
  "name": "PortFinder Hover",
  "version": "1.0.0",
  "description": "Hover over any IP or MAC address to look up its switch port via your PortFinder backend.",

  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
